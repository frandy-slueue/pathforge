# ════════════════════════════════════════════════════
# PathForge — Environment Variables Template
# ════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the .env file. It is in .gitignore.
#
# Run this to generate SECRET_KEY and JWT_SECRET_KEY:
#   openssl rand -hex 32
# ════════════════════════════════════════════════════


# ── App ──────────────────────────────────────────────
APP_NAME=PathForge
APP_ENV=development
# APP_ENV options: development | production
DEBUG=true


# ── Database (PostgreSQL) ────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pathforge
POSTGRES_USER=pathforge
POSTGRES_PASSWORD=changeme_strong_password_here


# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0


# ── Security ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl
JWT_SECRET_KEY=changeme_generate_with_openssl_different_value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30


# ── Storage (DigitalOcean Spaces) ────────────────────
# Leave blank for local development (files stored locally)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=pathforge-assets
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com


# ── Email (Resend) ───────────────────────────────────
# Get API key at resend.com — leave blank to skip emails in dev
RESEND_API_KEY=
FROM_EMAIL=noreply@pathforge.app


# ── PGAdmin (dev only) ───────────────────────────────
PGADMIN_EMAIL=admin@pathforge.local
PGADMIN_PASSWORD=changeme_pgadmin_password


# ── Frontend (Vite reads VITE_ prefix only) ──────────
VITE_API_URL=http://localhost/api/v1
VITE_APP_NAME=PathForge
VITE_APP_ENV=development
